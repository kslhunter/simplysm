{
  "name": "simplysm",
  "version": "13.0.0-beta.0",
  "description": "심플리즘 패키지",
  "author": "김석래",
  "repository": {
    "type": "git",
    "url": "https://github.com/kslhunter/simplysm.git"
  },
  "type": "module",
  "license": "Apache-2.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "tests/*"
  ],
  "volta": {
    "node": "20.19.6",
    "yarn": "4.12.0"
  },
  "scripts": {
    "---": "",
    "typecheck": "yarn run _sd-cli_ typecheck",
    "lint": "yarn run _sd-cli_ lint",
    "watch": "yarn run _sd-cli_ watch",
    "----": "",
    "_sd-cli_": "cross-env NODE_OPTIONS=--max-old-space-size=8192 tsx packages/cli/src/sd-cli.ts",
    "reinstall": "yarn install --refresh-lockfile",
    "postinstall": "playwright install"
  },
  "devDependencies": {
    "@simplysm/cli": "workspace:*",
    "@types/node": "^20.19.30",
    "@vitest/browser": "^4.0.17",
    "@vitest/browser-playwright": "^4.0.17",
    "@vitest/coverage-v8": "^4.0.17",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "jiti": "^2.6.1",
    "playwright": "^1.57.0",
    "prettier": "^3.8.1",
    "solid-js": "^1.9.10",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "vite": "^7.3.1",
    "vite-plugin-solid": "^2.11.10",
    "vite-tsconfig-paths": "^6.0.4",
    "vitest": "^4.0.17"
  }
}
